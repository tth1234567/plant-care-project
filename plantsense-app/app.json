{
  "expo": {
    "name": "植觉",
    "slug": "plantsense-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "plantsense",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1a2e1a",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.plantsense.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a2e1a"
      },
      "package": "com.plantsense.app",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "允许植觉使用摄像头进行植物识别和光度检测"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "允许植觉访问相册以选择植物照片",
          "cameraPermission": "允许植觉使用相机拍摄植物照片"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2d5a27"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "允许植觉获取位置以查询当地天气"
        }
      ],
      "@react-native-community/datetimepicker"
    ]
  }
}
